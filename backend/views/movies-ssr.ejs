/* NAVBAR */
.navbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:1rem 2rem;
    background:rgba(0,0,0,.45);
    backdrop-filter:blur(12px);
    position:sticky;
    top:0;
    z-index:1000;
    flex-wrap:wrap;
    gap:1rem;
}

.logo{
    font-size:1.6rem;
    font-weight:800;
    color:#2EC4B6;
}

.nav-links{
    display:flex;
    align-items:center;
    gap:1rem;
    flex-wrap:wrap;
}

.nav-links span,
.nav-links button{
    background:none;
    border:none;
    color:white;
    cursor:pointer;
    font-size:.95rem;
}

.nav-links span:hover,
.nav-links button:hover{
    color:#2EC4B6;
}

.search-box{
    background:rgba(255,255,255,.08);
    padding:.55rem 1rem;
    border-radius:8px;
}

.search-box input{
    background:none;
    border:none;
    outline:none;
    color:white;
    width:170px;
}

/* HERO */
.hero{
    text-align:center;
    padding:5rem 2rem;
}

.hero h1{
    font-size:3rem;
    margin-bottom:1rem;
}

