/* GRID */
.container{
    max-width:1400px;
    margin:auto;
    padding:2rem;
}

.movies-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(240px,1fr));
    gap:1.5rem;
}

/* CARD */
.movie-card{
    background:rgba(255,255,255,.06);
    border-radius:14px;
    overflow:hidden;
    cursor:pointer;
    transition:.3s;
    position:relative;
}

.movie-card:hover{
    transform:translateY(-6px);
}

.poster{
    width:100%;
    height:320px;
    object-fit:cover;
}

.movie-content{
    padding:1rem;
}

.title{
    font-weight:700;
    margin-bottom:.5rem;
}

.meta{
    display:flex;
    justify-content:space-between;
    font-size:.85rem;
    color:#ddd;
}

.fav-btn{
    position:absolute;
    top:12px;
    right:12px;
    width:38px;
    height:38px;
    border:none;
    border-radius:50%;
    background:rgba(0,0,0,.6);
    color:white;
    cursor:pointer;
}

.fav-btn:hover{
    background:#2EC4B6;
    color:black;
}

/* TOAST */
.toast{
    position:fixed;
    bottom:25px;
    right:25px;
    background:#2EC4B6;
    color:black;
    padding:1rem 1.4rem;
    border-radius:8px;
    transform:translateX(400px);
    transition:.3s;
    z-index:5000;
    font-weight:700;
}

.toast.show{
    transform:translateX(0);
}

/* MODAL */
.modal{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.7);
    display:none;
    justify-content:center;
    align-items:center;
    z-index:6000;
}

.modal.show{
    display:flex;
}

.modal-box{
    width:90%;
    max-width:420px;
    background:#16293f;
    padding:2rem;
    border-radius:15px;
    text-align:center;
}

.modal-box button{
    margin-top:1rem;
    border:none;
    background:#2EC4B6;
    padding:.7rem 1.5rem;
    border-radius:8px;
    cursor:pointer;
}

/* MOBILE */
@media(max-width:768px){

.hero h1{
    font-size:2rem;
}

.navbar{
    flex-direction:column;
}
}
</style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar">

<div class="logo">
<i class="fas fa-film"></i> MOVIEMATE
</div>

<div class="nav-links">
<span onclick="openModal('Welcome to MovieMate')">Home</span>
<span onclick="openModal('Browse all movies')">Movies</span>
<button onclick="goLogin()">Login</button>

<div class="search-box">
<input type="text" id="searchInput" placeholder="Search movie...">
</div>
</div>

</nav>

<!-- HERO -->
<section class="hero">
<h1>Discover Your Next <br><span>Favourite Movie</span></h1>
</section>

<!-- MOVIES -->
<div class="container">

<div class="movies-grid" id="moviesGrid">

<% movies.forEach(function(movie){ %>

<div class="movie-card"
data-id="<%= movie.id %>"
data-title="<%= movie.title %>"
data-rating="<%= movie.vote_average %>"
data-year="<%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>">

<img class="poster"
src="<%= movie.poster_path ? 'https://image.tmdb.org/t/p/w500' + movie.poster_path : '/static/media_files/image.png' %>">

<button class="fav-btn"
    data-id="<%= movie.id %>"
    data-title="<%= movie.title %>"
    onclick="event.stopPropagation(); addFav(this.dataset.id, this.dataset.title)">
    <i class="fas fa-heart"></i>
</button>

<div class="movie-content">

<div class="title"><%= movie.title %></div>

<div class="meta">
<span>⭐ <%= movie.vote_average %></span>
<span><%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %></span>
</div>

</div>
</div>

<% }) %>

</div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

