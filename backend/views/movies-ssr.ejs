<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>MOVIEMATE</title>

    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap"
        rel="stylesheet"
    >

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    >

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(
                135deg,
                #0B1F3A,
                #0F2A44
            );
            color: white;
            min-height: 100vh;
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            background: rgba(0, 0, 0, .45);
            backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 1000;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .logo-video {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            object-fit: cover;
        }

        .nav-links {
            display: flex;
            gap: 1rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .nav-links span,
        .nav-links button {
            background: none;
            border: none;
            color: white;
            cursor: pointer;
        }

        .search-box input {
            padding: .5rem;
            border-radius: 30px;
            border: none;
        }

        .hero {
            text-align: center;
            padding: 5rem 2rem;
        }

        .hero h1 {
            font-size: 3rem;
        }

        .hero span {
            color: #2EC4B6;
        }

        .container {
            max-width: 1400px;
            margin: auto;
            padding: 2rem;
        }

        .movies-grid {
            display: grid;
            grid-template-columns:
                repeat(auto-fill, minmax(240px, 1fr));
            gap: 1.5rem;
        }

        .movie-card {
            background: rgba(255,255,255,.06);
            border-radius: 14px;
            overflow: hidden;
            position: relative;
        }

        .poster {
            width: 100%;
            height: 320px;
            object-fit: cover;
        }

        .movie-content {
            padding: 1rem;
        }

        .title {
            font-weight: 700;
            margin-bottom: .5rem;
        }

        .meta {
            display: flex;
            justify-content: space-between;
            font-size: .85rem;
        }

        .fav-btn {
            position: absolute;
            top: 12px;
            right: 12px;
            width: 38px;
            height: 38px;
            border: none;
            border-radius: 50%;
            cursor: pointer;
        }

        .toast {
            position: fixed;
            bottom: 25px;
            right: 25px;
            padding: 1rem 1.4rem;
            background: #2EC4B6;
            color: black;
            border-radius: 8px;
            display: none;
        }

        .toast.show {
            display: block;
        }

        .modal {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.7);
            display: none;
            justify-content: center;
            align-items: center;
        }

        .modal.show {
            display: flex;
        }

        .modal-box {
            background: #16293f;
            padding: 2rem;
            border-radius: 15px;
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2rem;
            }

            .navbar {
                flex-direction: column;
            }
        }
    </style>
</head>

<body>

<nav class="navbar">

    <div class="logo">
        <video
            class="logo-video"
            src="/static/media_files/movielight.mp4"
            autoplay
            loop
            muted
            playsinline
        ></video>
    </div>

    <div class="nav-links">

        <span onclick="openModal('Welcome to MovieMate')">Home</span>
        <button class="nav-action-btn primary" id="loginBtn" onclick="goLogin()">Login</button>
        <button class="nav-action-btn" id="logoutBtn" onclick="logout()">Logout</button>


        <span onclick="openModal('Welcome to MovieMate')">
            Home
        </span>

        <span onclick="openModal('Browse all movies')">
            Movies
        </span>

        <span onclick="openModal('TV Shows - Coming soon')">
            TV Shows
        </span>

        <button
            id="loginBtn"
            onclick="goLogin()"
        >
            Login
        </button>

        <button
            id="logoutBtn"
            onclick="logout()"
        >
            Logout
        </button>

        <div class="search-box">
            <i class="fas fa-search"></i>

            <input
                type="text"
                id="searchInput"
                placeholder="Search movie..."
            >
        </div>

    </div>

</nav>

<section class="hero">
    <h1>
        Discover Your Next
        <br>
        <span>Favourite Movie</span>
    </h1>
</section>

<div class="container">

    <div
        class="movies-grid"
        id="moviesGrid"
    >

        <% if (typeof movies !== 'undefined' && movies.length) { %>

            <% movies.forEach(function(movie){ %>

                <div
                    class="movie-card"
                    data-id="<%= movie.id %>"
                >

                    <img
                        class="poster"
                        src="<%= movie.poster_path ? 'https://image.tmdb.org/t/p/w500' + movie.poster_path : '/static/media_files/image.png' %>"
                    >

                    <button
                        class="fav-btn"
                        data-id="<%= movie.id %>"
                        data-title="<%= movie.title %>"
                    >
                        <i class="fas fa-heart"></i>
                    </button>

                    <div class="movie-content">

                        <div class="title">
                            <%= movie.title %>
                        </div>

                        <div class="meta">
                            <span>
                                ⭐ <%= movie.vote_average %>
                            </span>

                            <span>
                                <%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>
                            </span>
                        </div>

                    </div>

                </div>

            <% }); %>

        <% } else { %>

            <p>Loading movies...</p>

        <% } %>

    </div>

</div>

<div
    class="toast"
    id="toast"
></div>

<div
    class="modal"
    id="modal"
>
    <div class="modal-box">

        <h2>MovieMate</h2>

        <p id="modalText"></p>

        <button onclick="closeModal()">
            Close
        </button>

    </div>
</div>

<script src="/socket.io/socket.io.js"></script>

<script>
const grid =
    document.getElementById("moviesGrid");

let originalHTML =
    grid ? grid.innerHTML : "";

function showToast(message) {
    const toast =
        document.getElementById("toast");

    toast.textContent = message;
    toast.classList.add("show");

    setTimeout(() => {
        toast.classList.remove("show");
    }, 2000);
}

function goLogin() {
    window.location.href = "/login";
}

function logout() {
    localStorage.removeItem("token");
    showToast("Logged out");
}

function openModal(message) {
    document.getElementById(
        "modalText"
    ).textContent = message;

    document.getElementById(
        "modal"
    ).classList.add("show");
}

function closeModal() {
    document.getElementById(
        "modal"
    ).classList.remove("show");
}
</script>

</body>
</html>