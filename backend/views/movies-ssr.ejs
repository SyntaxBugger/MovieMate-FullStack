<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MOVIEMATE - SSR Movies | Netflix Style</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: white;
            min-height: 100vh;
            background: linear-gradient(135deg, #0B1F3A 0%, #0F2A44 100%);
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.3); }
        ::-webkit-scrollbar-thumb { background: #2EC4B6; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #4EE1D3; }

        /* Navbar */
        .navbar {
            background: rgba(10, 20, 30, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid rgba(46, 196, 182, 0.2);
            flex-wrap: wrap;
            gap: 1rem;
            transition: all 0.3s;
        }

        .navbar.scrolled {
            padding: 0.7rem 2rem;
            background: rgba(10, 20, 30, 0.95);
            border-bottom-color: rgba(46, 196, 182, 0.4);
        }

        .logo {
            color: #2EC4B6;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            transition: transform 0.3s;
        }

        .logo:hover {
            transform: scale(1.05);
        }

        .logo-video {
            width: 50px;
            height: 50px;
            object-fit: contain;
            border-radius: 12px;
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .nav-links span {
            color: #FFFFFF;
            font-weight: 500;
            font-size: 1rem;
            cursor: pointer;
            transition: color 0.3s;
            padding: 0.5rem 0;
        }

        .nav-links span:hover {
            color: #2EC4B6;
        }

        /* Search Box */
        .search-box {
            display: flex;
            align-items: center;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            border-radius: 8px;
            padding: 0.6rem 1.2rem;
            gap: 10px;
            border: 1px solid rgba(46, 196, 182, 0.3);
            transition: all 0.3s;
        }

        .search-box:focus-within {
            border-color: #2EC4B6;
            box-shadow: 0 0 5px rgba(46, 196, 182, 0.5);
        }

        .search-box i {
            color: #C7D2FE;
            font-size: 1rem;
        }

        .search-box input {
            background: transparent;
            border: none;
            color: white;
            padding: 0.3rem 0;
            font-size: 0.95rem;
            width: 180px;
            outline: none;
        }

        .search-box input::placeholder {
            color: #C7D2FE;
            opacity: 0.6;
        }

        .nav-action-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.75rem 1.3rem;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.18);
            background: rgba(255, 255, 255, 0.08);
            color: #E0E7FF;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s ease;
            letter-spacing: 0.01em;
        }

        .nav-action-btn:hover {
            background: rgba(46, 196, 182, 0.14);
            border-color: rgba(46, 196, 182, 0.4);
            color: #A7F3D0;
            transform: translateY(-1px);
        }

        .nav-action-btn.primary {
            background: #2EC4B6;
            color: #0B1F3A;
            border-color: transparent;
        }

        .nav-action-btn.primary:hover {
            background: #4EE1D3;
            color: #0B1F3A;
        }

        .nav-links button {
            margin-left: 0.5rem;
        }

        /* Hero Section */
        .hero {
            padding: 6rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            margin-bottom: 2rem;
            background: url('/static/media_files/image.png') center/cover no-repeat;
            border-radius: 0 0 30px 30px;
            min-height: 550px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, 
                rgba(11, 31, 58, 0.85) 0%,
                rgba(15, 42, 68, 0.75) 50%,
                rgba(0, 0, 0, 0.6) 100%);
            backdrop-filter: blur(2px);
            z-index: 1;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 800px;
            margin: 0 auto;
        }

        .hero h1 {
            font-size: 4rem;
            font-weight: 800;
            margin-bottom: 1rem;
            text-shadow: 0 2px 15px rgba(0,0,0,0.5);
            animation: fadeInUp 0.8s ease;
        }

        .hero h1 span {
            color: #2EC4B6;
            text-shadow: 0 0 20px rgba(46,196,182,0.5);
        }

        .hero p {
            color: #E0E7FF;
            max-width: 600px;
            margin: 0 auto;
            font-size: 1.2rem;
            line-height: 1.6;
            text-shadow: 0 1px 5px rgba(0,0,0,0.3);
        }

        .hero-buttons {
            margin-top: 2rem;
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary {
            background: #2EC4B6;
            color: #0B1F3A;
            border: none;
            padding: 1rem 2.5rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-primary:hover {
            background: #4EE1D3;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(46,196,182,0.3);
        }

        .btn-secondary {
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(8px);
            color: white;
            border: 1px solid rgba(255,255,255,0.3);
            padding: 1rem 2.5rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-secondary:hover {
            border-color: #2EC4B6;
            color: #2EC4B6;
            background: rgba(0,0,0,0.7);
            transform: translateY(-2px);
        }

        /* Container */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* SSR Badge */
        .ssr-badge {
            background: rgba(46, 196, 182, 0.15);
            backdrop-filter: blur(10px);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            margin: 1.5rem 0;
            font-size: 0.85rem;
            border: 1px solid rgba(46, 196, 182, 0.3);
            color: #2EC4B6;
        }

        /* Filters */
        .filters {
            display: flex;
            gap: 1rem;
            margin: 2rem 0 1.5rem;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
        }

        .filter-group {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .filter-btn {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            padding: 0.6rem 1.5rem;
            border-radius: 50px;
            color: #C7D2FE;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
        }

        .filter-btn:hover, .filter-btn.active {
            background: #2EC4B6;
            color: #0B1F3A;
            border-color: #2EC4B6;
        }

        .sort-select {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            padding: 0.6rem 1.2rem;
            border-radius: 50px;
            color: #FFFFFF;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
        }

        /* Stats Section */
        .stats-section {
            display: flex;
            gap: 1rem;
            margin: 2rem 0;
            flex-wrap: wrap;
        }

        .stat-card {
            background: rgba(20, 30, 45, 0.5);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            padding: 1.2rem 1.8rem;
            flex: 1;
            min-width: 140px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.3s;
        }

        .stat-card:hover {
            border-color: rgba(46, 196, 182, 0.4);
            transform: translateY(-3px);
            background: rgba(20, 30, 45, 0.7);
        }

        .stat-value {
            font-size: 1.8rem;
            font-weight: 700;
            color: #2EC4B6;
        }

        .stat-label {
            font-size: 0.8rem;
            color: #C7D2FE;
            margin-top: 0.3rem;
        }

        /* Movies Grid */
        .movies-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 28px;
            margin: 2rem 0;
        }

        /* Movie Card */
        .movie-card {
            position: relative;
            border-radius: 12px;
            overflow: hidden;
            height: 420px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        }

        .movie-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(46, 196, 182, 0.2);
        }

        .movie-bg {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            filter: blur(8px) brightness(0.4);
            transform: scale(1.1);
            transition: all 0.4s ease;
        }

        .movie-card:hover .movie-bg {
            filter: blur(6px) brightness(0.5);
            transform: scale(1.15);
        }

        .movie-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, 
                rgba(0, 0, 0, 0.3) 0%,
                rgba(0, 0, 0, 0.6) 100%);
            z-index: 1;
        }

        .movie-content {
            position: relative;
            z-index: 2;
            height: 100%;
            background: rgba(20, 30, 45, 0.55);
            backdrop-filter: blur(12px);
            display: flex;
            flex-direction: column;
            padding: 20px;
            transition: all 0.3s ease;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
        }

        .movie-card:hover .movie-content {
            background: rgba(20, 30, 45, 0.7);
            border-color: rgba(46, 196, 182, 0.3);
        }

        .poster {
            width: 100%;
            height: 260px;
            object-fit: cover;
            border-radius: 8px;
            transition: transform 0.4s ease;
        }

        .movie-card:hover .poster {
            transform: scale(1.03);
        }

        .title {
            font-weight: 700;
            font-size: 1.1rem;
            margin-top: 12px;
            margin-bottom: 6px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            color: white;
        }

        .meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.85rem;
        }

        .rating {
            color: #FFD700;
            display: flex;
            align-items: center;
            gap: 4px;
            background: rgba(0, 0, 0, 0.5);
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
        }

        .year {
            color: #C7D2FE;
            background: rgba(0, 0, 0, 0.5);
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
            font-size: 0.75rem;
        }

        .fav-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            width: 38px;
            height: 38px;
            border-radius: 50%;
            color: white;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }

        .fav-btn:hover {
            background: #2EC4B6;
            transform: scale(1.15);
        }

        .fav-btn.active {
            background: #2EC4B6;
            color: #0B1F3A;
        }

        /* Pagination */
        .pagination {
            display: flex;
            justify-content: center;
            gap: 0.5rem;
            margin: 3rem 0;
            flex-wrap: wrap;
        }

        .page-btn {
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            padding: 0.6rem 1.2rem;
            border-radius: 8px;
            color: white;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.9rem;
        }

        .page-btn:hover, .page-btn.active {
            background: #2EC4B6;
            color: #0B1F3A;
        }

        .page-btn.disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Toast */
        .toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: rgba(46, 196, 182, 0.9);
            backdrop-filter: blur(10px);
            color: #0B1F3A;
            padding: 1rem 2rem;
            border-radius: 8px;
            font-weight: 600;
            transform: translateX(400px);
            transition: transform 0.3s ease;
            z-index: 1100;
            font-size: 0.9rem;
        }

        .toast.show {
            transform: translateX(0);
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(8px);
            z-index: 2000;
            justify-content: center;
            align-items: center;
        }

        .modal.show {
            display: flex;
            animation: fadeIn 0.3s ease;
        }

        .modal-content {
            background: rgba(20, 30, 45, 0.95);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            max-width: 500px;
            width: 90%;
            padding: 2rem;
            text-align: center;
            border: 1px solid rgba(46, 196, 182, 0.4);
        }

        .modal-content h3 {
            margin-bottom: 1rem;
            color: #2EC4B6;
            font-size: 1.5rem;
        }

        .modal-content p {
            margin-bottom: 1.5rem;
            color: #C7D2FE;
            line-height: 1.6;
            white-space: pre-line;
            font-size: 1rem;
        }

        .modal-close {
            background: #2EC4B6;
            border: none;
            padding: 0.6rem 1.8rem;
            border-radius: 8px;
            color: #0B1F3A;
            font-weight: 600;
            cursor: pointer;
            font-size: 1rem;
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 2rem;
            margin-top: 3rem;
            border-top: 1px solid rgba(46, 196, 182, 0.15);
            color: #C7D2FE;
            font-size: 0.85rem;
            background: rgba(10, 20, 30, 0.5);
        }

        .footer i {
            color: #2EC4B6;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .navbar { flex-direction: column; text-align: center; }
            .nav-links { justify-content: center; }
            .hero { padding: 3rem 1rem; min-height: 400px; }
            .hero h1 { font-size: 2.2rem; }
            .hero p { font-size: 0.95rem; }
            .container { padding: 0 1rem; }
            .movies-grid { grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
            .movie-card { height: 360px; }
            .poster { height: 220px; }
            .logo-video { width: 40px; height: 40px; }
            .logo { font-size: 1.4rem; }
        }

        @media (max-width: 480px) {
            .movies-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.8rem; }
            .movie-card { height: 320px; }
            .poster { height: 190px; }
            .title { font-size: 0.9rem; }
        }
    </style>
</head>

<body>

<!-- NAVBAR WITH LARGER LOGO VIDEO -->
<nav class="navbar" id="navbar">
    <div class="logo">
        <video class="logo-video" src="/static/media_files/movielight.mp4" autoplay loop muted playsinline></video>
    </div>
    <div class="nav-links">
        <span onclick="openModal('Home - Welcome to MovieMate!')">Home</span>
        <span onclick="openModal('Movies - Browse our collection of popular movies.')">Movies</span>
        <span onclick="openModal('TV Shows - Coming soon!')">TV Shows</span>
        <button class="nav-action-btn primary" id="loginBtn" onclick="goLogin()">Login</button>
        <button class="nav-action-btn" id="logoutBtn" onclick="logout()">Logout</button>
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" id="searchInput" placeholder="Search for movies...">
        </div>
    </div>
</nav>

<!-- HERO SECTION -->
<div class="hero">
    <div class="hero-content">
        <h1>Discover Your Next<br><span>Favourite Movie</span></h1>
        <p>Entertainment Hub - Explore thousands of movies and TV shows with MovieMate. Find hidden gems, trending content, and personalized recommendations all in one place.</p>
        <div class="hero-buttons">
            <button class="btn-primary" id="exploreBtn">Explore Movies</button>
            <button class="btn-secondary" id="learnMoreBtn">Learn More</button>
        </div>
    </div>
</div>

<div class="container">
    <div class="ssr-badge">
        <i class="fas fa-server"></i> Server-Side Rendered with EJS | Netflix Style
    </div>

    <!-- Filters -->
    <div class="filters">
        <div class="filter-group">
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="action">Action</button>
            <button class="filter-btn" data-filter="drama">Drama</button>
            <button class="filter-btn" data-filter="comedy">Comedy</button>
        </div>
        <select class="sort-select" id="sortSelect">
            <option value="default">Sort by: Default</option>
            <option value="rating">Sort by: Rating ↓</option>
            <option value="year">Sort by: Year ↓</option>
            <option value="title">Sort by: Title A-Z</option>
        </select>
    </div>

    <!-- Stats -->
    <div class="stats-section">
        <div class="stat-card">
            <div class="stat-value" id="totalMovies">0</div>
            <div class="stat-label">Movies Available</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="avgRating">0</div>
            <div class="stat-label">Avg Rating</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="favouritesCount">0</div>
            <div class="stat-label">My Favourites</div>
        </div>
    </div>

    <!-- Movies Grid -->
    <div class="movies-grid">

    <% if (movies.length === 0) { %>
        <div style="text-align:center; grid-column:1/-1; padding:3rem;">
            No movies found
        </div>
    <% } %>

    <% movies.forEach(movie => { %>
        <div class="movie-card"
            data-title="<%= movie.title %>"
            data-year="<%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>"
            data-rating="<%= movie.vote_average %>">

            <div class="movie-bg"
                style="background-image: url('https://image.tmdb.org/t/p/original<%= movie.poster_path %>')">
            </div>

            <div class="movie-content">

                <img class="poster"
                    src="<%= movie.poster_path 
                        ? 'https://image.tmdb.org/t/p/w500' + movie.poster_path 
                        : 'https://via.placeholder.com/300x450?text=No+Poster' %>"
                />

                <button class="fav-btn"
                    onclick="event.stopPropagation(); addFav(<%= movie.id %>, '<%= movie.title %>')">
                    <i class="fas fa-heart"></i>
                </button>

                <div class="title"><%= movie.title %></div>

                <div class="meta">
                    <span class="rating">
                        <i class="fas fa-star"></i> <%= movie.vote_average %>
                    </span>
                    <span class="year">
                        <%= movie.release_date ? movie.release_date.split('-')[0] : 'N/A' %>
                    </span>
                </div>

            </div>
        </div>
    <% }) %>

</div>
</div>

<!-- Toast -->
<div class="toast" id="toast">Movie added to favourites!</div>

<!-- Modal -->
<div class="modal" id="modal">
    <div class="modal-content">
        <h3><i class="fas fa-info-circle"></i> MovieMate</h3>
        <p id="modalMessage">Welcome to MovieMate!</p>
        <button class="modal-close" onclick="closeModal()">Got it!</button>
    </div>
</div>

<!-- Footer -->
<div class="footer">
    <p>© 2026 <i class="fas fa-film"></i> MOVIEMATE | All Rights Reserved</p>
    <p>Server-Side Rendered (SSR) with EJS | Netflix Style Design</p>
</div>
<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();

socket.on("userActivity", (data) => {
    showToast(data.message);
});

socket.on("notification", (msg) => {
    showToast(msg);
});
    function showToast(message) {
        const toast = document.getElementById('toast');
        toast.textContent = message;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2000);
    }
    function goLogin() {
        window.location.href = "/login";
    }

    function logout() {
        localStorage.removeItem('token');
        showToast('Logged out successfully');
        updateAuthButtons();
        setTimeout(() => window.location.href = '/login', 900);
    }

    function updateAuthButtons() {
        const token = localStorage.getItem('token');
        const loginBtn = document.getElementById('loginBtn');
        const logoutBtn = document.getElementById('logoutBtn');
        if (loginBtn && logoutBtn) {
            loginBtn.style.display = token ? 'none' : 'inline-flex';
            logoutBtn.style.display = token ? 'inline-flex' : 'none';
        }
    }

    document.addEventListener('DOMContentLoaded', updateAuthButtons);
    updateAuthButtons();

    

   
    

  

    

    function openModal(message) {
        document.getElementById('modalMessage').textContent = message;
        document.getElementById('modal').classList.add('show');
    }

    function closeModal() {
        document.getElementById('modal').classList.remove('show');
    }
    document.getElementById('searchInput').addEventListener('input', async function () {
    const query = this.value.trim();

    if (!query) {
        location.reload(); // fallback to SSR
        return;
    }

    const res = await fetch(`/api/tmdb/search/movie?query=${query}`);
    const data = await res.json();

    const grid = document.querySelector('.movies-grid');

    if (!data.results || data.results.length === 0) {
        grid.innerHTML = `<div style="text-align:center; grid-column:1/-1;">No results</div>`;
        return;
    }

    grid.innerHTML = data.results.map(movie => `
        <div class="movie-card">
            <div class="movie-bg" style="background-image:url('https://image.tmdb.org/t/p/original${movie.poster_path}')"></div>
            <div class="movie-content">
                <img class="poster" src="https://image.tmdb.org/t/p/w500${movie.poster_path}">
                <div class="title">${movie.title}</div>
                <div class="meta">
                    ${movie.vote_average} |
                    ${movie.release_date?.split('-')[0] || 'N/A'}
                </div>
            </div>
        </div>
    `).join('');
});

function addFav(id, title) {
    const token = localStorage.getItem("token");

    if (!token) {
        alert("Login first");
        return;
    }

    fetch("/api/library/add", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + token
        },
        body: JSON.stringify({
            movieId: id,
            title: title,
            poster_path: "",
            media_type: "movie"
        })
    })
    .then(() => showToast(`Added "${title}" ❤️`))
}
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        if (window.scrollY > 50) {
            navbar.classList.add('scrolled');
        } else {
            navbar.classList.remove('scrolled');
        }
    });

    // Initialize
    
