/* ADD FAV */
async function addFav(id,title){

    const token = localStorage.getItem("token");

    if(!token){
        alert("Please login first");
        return;
    }

    try{

        const res = await fetch("/api/library/add",{
            method:"POST",
            headers:{
                "Content-Type":"application/json",
                "Authorization":"Bearer " + token
            },
            body:JSON.stringify({
                movieId:id,
                title:title,
                media_type:"movie",
                poster_path:""
            })
        });

        const data = await res.json();

        if(data.success){
            showToast("Added " + title + " ❤️");
        }else{
            showToast("Failed");
        }

    }catch(error){
        showToast("Server Error");
    }

}

