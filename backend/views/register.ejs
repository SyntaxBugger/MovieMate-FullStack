<!DOCTYPE html>
<html lang="en">
<head>
    <!-- ============================================ -->
    <!-- META DATA -->
    <!-- ============================================ -->
    <meta charset="UTF-8">
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    >

    <title>MovieMate · Create Account</title>

    <!-- ============================================ -->
    <!-- FONTS & ICONS -->
    <!-- ============================================ -->
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet"
    >

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    >

    <!-- ============================================ -->
    <!-- STYLES -->
    <!-- ============================================ -->
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 1.5rem;
            font-family: 'Inter', system-ui, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #0B1F3A 0%, #0F2A44 100%);
            color: #edf2f8;
            position: relative;
        }

        /* Animated grain background */
        body::before {
            content: "";
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;

            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 2000 2000' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.025'/%3E%3C/svg%3E");
        }

        /* ============================================ */
        /* CARD */
        /* ============================================ */
        .page-card {
            position: relative;
            z-index: 2;
            width: min(500px, 100%);
            padding: 2.5rem 2rem;
            border-radius: 2rem;
            overflow: hidden;

            background: rgba(12, 22, 35, 0.78);
            backdrop-filter: blur(18px);

            border: 1px solid rgba(46, 196, 182, 0.25);

            box-shadow:
                0 25px 45px -12px rgba(0, 0, 0, 0.5),
                0 0 0 0.5px rgba(46, 196, 182, 0.15) inset;

            transition: transform 0.25s ease, box-shadow 0.3s ease;
        }

        .page-card:hover {
            transform: translateY(-3px);
            border-color: rgba(46, 196, 182, 0.4);
            box-shadow: 0 30px 50px -15px rgba(0, 0, 0, 0.6);
        }

        .glow-orb {
            position: absolute;
            top: -100px;
            right: -70px;
            z-index: -1;

            width: 280px;
            height: 280px;
            border-radius: 50%;

            background: radial-gradient(
                circle,
                rgba(46, 196, 182, 0.2) 0%,
                rgba(14, 165, 233, 0) 70%
            );

            filter: blur(60px);
            pointer-events: none;
        }

        /* ============================================ */
        /* HEADER */
        /* ============================================ */
        .brand-header {
            text-align: center;
            margin-bottom: 1.5rem;
        }

        .mini-video-logo {
            display: flex;
            justify-content: center;
            margin-bottom: 1rem;
        }

        .mini-video {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            overflow: hidden;

            background: #0a1a2c;
            border: 0.5px solid rgba(46, 196, 182, 0.5);

            box-shadow: 0 4px 14px rgba(46, 196, 182, 0.35);
            transition: transform 0.2s;
        }

        .mini-video:hover {
            transform: scale(1.02);
        }

        .mini-video video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        h2 {
            margin-bottom: 0.35rem;
            text-align: center;
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.02em;

            background: linear-gradient(
                135deg,
                #FFFFFF 15%,
                #B2F0EA 50%,
                #2EC4B6 90%
            );

            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .subhead {
            text-align: center;
            font-size: 0.85rem;
            color: #94a3b8;
            margin-bottom: 1.5rem;
        }

        /* ============================================ */
        /* FORM */
        /* ============================================ */
        form {
            display: flex;
            flex-direction: column;
            gap: 1.2rem;
            margin-top: 0.5rem;
        }

        .input-group {
            position: relative;
            width: 100%;
        }

        .input-group i {
            position: absolute;
            top: 50%;
            left: 1rem;
            z-index: 1;

            transform: translateY(-50%);
            color: #5f7f9e;
            font-size: 1rem;

            pointer-events: none;
            transition: color 0.2s;
        }

        input {
            width: 100%;
            padding: 0.9rem 1rem 0.9rem 2.6rem;

            border-radius: 1rem;
            border: 1px solid rgba(46, 196, 182, 0.2);

            background: rgba(10, 20, 35, 0.85);
            backdrop-filter: blur(4px);

            color: #e2e8f0;
            font-size: 0.95rem;
            font-family: 'Inter', sans-serif;

            transition: all 0.2s ease;
        }

        input::placeholder {
            color: #6f8fae;
            font-weight: 450;
        }

        input:focus {
            outline: none;
            transform: translateY(-1px);

            background: rgba(15, 28, 45, 0.95);
            border-color: #2EC4B6;

            box-shadow: 0 0 0 4px rgba(46, 196, 182, 0.15);
        }

        /* ============================================ */
        /* BUTTON */
        /* ============================================ */
        button {
            width: 100%;
            margin-top: 0.5rem;
            padding: 0.9rem 1.2rem;

            border: none;
            border-radius: 999px;

            background: linear-gradient(
                105deg,
                #2EC4B6 0%,
                #14b8db 100%
            );

            color: #0a121f;
            font-size: 1rem;
            font-weight: 700;
            font-family: 'Inter', sans-serif;

            cursor: pointer;

            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;

            box-shadow: 0 8px 18px -6px rgba(46, 196, 182, 0.4);
            transition: all 0.25s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        }

        button:hover {
            transform: translateY(-2px);
            filter: brightness(1.06);

            box-shadow: 0 14px 24px -10px rgba(46, 196, 182, 0.55);
        }

        button:active {
            transform: translateY(1px);
        }

        button:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }

        /* ============================================ */
        /* FOOTER */
        /* ============================================ */
        .auth-footer {
            margin-top: 1.8rem;
            padding-top: 1.4rem;

            text-align: center;
            font-size: 0.9rem;
            color: #94a3b8;

            border-top: 0.5px solid rgba(46, 196, 182, 0.2);
        }

        .auth-footer a {
            color: #8ee4db;
            text-decoration: none;
            font-weight: 600;
        }

        .auth-footer a:hover {
            color: #2EC4B6;
            text-decoration: underline;
        }

        /* ============================================ */
        /* PASSWORD STRENGTH */
        /* ============================================ */
        .password-strength {
            margin-top: -0.5rem;
            margin-bottom: 0.2rem;
            padding-left: 0.5rem;
            font-size: 0.7rem;
        }

        .strength-text {
            color: #8aa1c0;
        }


        /* Error message */
        .error-message {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #fca5a5;
            padding: 0.8rem 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Toast notification — same style as dashboard */

        /* ============================================ */
        /* TOAST */
        /* ============================================ */

        #toast {
            position: fixed;
            bottom: 28px;
            left: 50%;
            z-index: 1000;

            min-width: 260px;
            padding: 0.8rem 1.5rem;

            transform: translateX(-50%) translateY(20px);
            opacity: 0;

            border-radius: 40px;
            border: 1px solid rgba(46, 196, 182, 0.4);

            background: rgba(12, 22, 35, 0.96);
            backdrop-filter: blur(12px);

            color: #f0f6fe;
            font-size: 0.9rem;
            font-weight: 500;
            text-align: center;

            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);

            transition: opacity 0.25s ease, transform 0.25s ease;
            pointer-events: none;
        }

        #toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        /* ============================================ */
        /* RESPONSIVE */
        /* ============================================ */
        @media (max-width: 500px) {
            .page-card {
                padding: 1.8rem 1.3rem;
            }

            h2 {
                font-size: 1.7rem;
            }

            input {
                padding: 0.8rem 0.8rem 0.8rem 2.4rem;
            }
        }
    </style>
</head>

<body>

    <!-- ============================================ -->
    <!-- REGISTER CARD -->
    <!-- ============================================ -->
    <div class="page-card">

        <div class="glow-orb"></div>

        <!-- Logo -->
        <div class="mini-video-logo">
            <div class="mini-video" id="miniLogoVideo">
                <video autoplay loop muted playsinline>
                    <source
                        src="/static/media_files/movielight.mp4"
                        type="video/mp4"
                    >
                </video>
            </div>
        </div>

        <!-- Header -->
        <div class="brand-header">
            <h2>Create Account</h2>
            <div class="subhead">
                Join MovieMate and start your cinematic journey
            </div>
        </div>

        <!-- Form -->
        <form id="registerForm">

            <div class="input-group">
                <i class="fas fa-user"></i>
                <input
                    type="text"
                    id="name"
                    placeholder="Full name"
                    required
                    autocomplete="name"
                >
            </div>

            <div class="input-group">
                <i class="fas fa-envelope"></i>
                <input
                    type="email"
                    id="email"
                    placeholder="Email address"
                    required
                    autocomplete="email"
                >
            </div>

            <div class="input-group">
                <i class="fas fa-lock"></i>
                <input
                    type="password"
                    id="password"
                    placeholder="Password"
                    required
                    autocomplete="new-password"
                >
            </div>

            <div class="password-strength" id="passwordStrength">
                <span class="strength-text">
                    <i class="fas fa-shield-alt"></i>
                    Use 6+ characters
                </span>
            </div>

            <button type="submit" id="registerBtn">
                <i class="fas fa-user-plus"></i>
                Register
            </button>
        </form>

        <!-- Footer -->
        <div class="auth-footer">
            <span>Already have an account? </span>
            <a href="/login">Sign in</a>
        </div>
    </div>


    <% if (error) { %>
    <div class="error-message">
        <i class="fas fa-exclamation-triangle"></i> <%= error %>
    </div>
    <% } %>

    <form id="registerForm">
        <div class="input-group">
            <i class="fas fa-user"></i>
            <input type="text" id="name" placeholder="Full name" required autocomplete="name">
        </div>
        
        <div class="input-group">
            <i class="fas fa-envelope"></i>
            <input type="email" id="email" placeholder="Email address" required autocomplete="email">
        </div>
        
        <div class="input-group">
            <i class="fas fa-lock"></i>
            <input type="password" id="password" placeholder="Password" required autocomplete="new-password">
        </div>
        <div class="password-strength" id="passwordStrength">
            <span class="strength-text"><i class="fas fa-shield-alt"></i> Use 6+ characters</span>
        </div>
        
        <button type="submit" id="registerBtn">
            <i class="fas fa-user-plus"></i> Register
        </button>
    </form>

    <!-- Toast -->
    <div id="toast"></div>


    <!-- Socket -->
    <script src="/socket.io/socket.io.js"></script>

    <!-- ============================================ -->
    <!-- SCRIPT -->
    <!-- ============================================ -->
    <script>
        /* Toast */
        function showToast(message, isError = false) {
            const toast = document.getElementById("toast");

            toast.textContent = message;
            toast.classList.add("show");

            if (isError) {
                toast.style.background = "rgba(30,20,35,.96)";
                toast.style.borderColor = "#f97316";
            } else {
                toast.style.background = "rgba(12,22,35,.96)";
                toast.style.borderColor = "rgba(46,196,182,.4)";
            }

            setTimeout(() => {
                toast.classList.remove("show");
            }, 2600);
        }

        /* Password Strength */
        const passwordInput = document.getElementById("password");
        const strengthDiv = document.getElementById("passwordStrength");

        passwordInput.addEventListener("input", function () {
            const val = this.value;
            let msg = "";

            if (val.length === 0) {
                msg = "Use 6+ characters";
            } else if (val.length < 6) {
                msg = "⚠️ Weak — at least 6 characters";
            } else if (val.length < 10) {
                msg = "✓ Fair — good start";
            } else {
                msg = "✓ Strong — nice!";
            }

            strengthDiv.innerHTML =
                `<span class="strength-text">
                    <i class="fas fa-shield-alt"></i> ${msg}
                </span>`;
        });

        /* Socket */
        if (typeof io !== "undefined") {
            try {
                const socket = io();

                socket.on("userActivity", (data) => {
                    if (data?.message) showToast(data.message);
                });

                socket.on("notification", (msg) => {
                    if (msg) showToast(msg);
                });
            } catch (error) {
                console.log("Socket optional");
            }
        }

        /* Register */
        const registerForm = document.getElementById("registerForm");
        const registerBtn = document.getElementById("registerBtn");

        registerForm.addEventListener("submit", async (e) => {
            e.preventDefault();

            const name = document.getElementById("name").value.trim();
            const email = document.getElementById("email").value.trim();
            const password = document.getElementById("password").value;

            if (!name || !email || !password) {
                showToast("Please fill in all fields", true);
                return;
            }

            if (name.length < 2) {
                showToast("Name must be at least 2 characters", true);
                return;
            }

            if (!email.includes("@")) {
                showToast("Enter valid email", true);
                return;
            }

            if (password.length < 6) {
                showToast("Password must be at least 6 characters", true);
                return;
            }

            const original = registerBtn.innerHTML;

            registerBtn.innerHTML =
                '<i class="fas fa-spinner fa-pulse"></i> Creating account...';

            registerBtn.disabled = true;

            try {
                const res = await fetch("/api/auth/register", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        Accept: "application/json"
                    },
                    body: JSON.stringify({
                        name,
                        email,
                        password
                    })
                });

                const data = await res.json();

                if (res.status === 201 || data.success) {
                    showToast(
                        data.message ||
                        "Account created successfully!"
                    );

                    setTimeout(() => {
                        window.location.href = "/login";
                    }, 1200);

                } else {
                    showToast(
                        data.message ||
                        "Registration failed",
                        true
                    );

                    registerBtn.innerHTML = original;
                    registerBtn.disabled = false;
                }

            } catch (error) {
                showToast(
                    "Server error. Please try again.",
                    true
                );

                registerBtn.innerHTML = original;
                registerBtn.disabled = false;
            }
        });

        /* Remove stale token */
        localStorage.removeItem("token");
    </script>

</body>
</html>