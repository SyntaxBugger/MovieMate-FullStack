<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background: radial-gradient(circle at top left, rgba(46, 196, 182, 0.18), transparent 20%),
                        linear-gradient(180deg, #07101d 0%, #0f2438 100%);
            color: #e2e8f0;
            display: grid;
            place-items: center;
            padding: 2rem;
        }

        .dashboard-card {
            width: min(520px, 100%);
            padding: 2.5rem 2rem;
            border-radius: 28px;
            background: rgba(10, 20, 35, 0.92);
            border: 1px solid rgba(46, 196, 182, 0.15);
            box-shadow: 0 35px 80px rgba(0, 0, 0, 0.35);
            backdrop-filter: blur(16px);
            text-align: center;
        }

        h1 {
            font-size: clamp(2rem, 4vw, 3rem);
            margin-bottom: 0.75rem;
            letter-spacing: -0.05em;
            text-shadow: 0 10px 30px rgba(46, 196, 182, 0.18);
        }

        p.subtitle {
            color: #94a3b8;
            margin-bottom: 2rem;
            line-height: 1.7;
        }

        .actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 1.5rem;
        }

        .action-btn {
            padding: 0.95rem 1.8rem;
            font-size: 1rem;
            font-weight: 700;
            border-radius: 999px;
            border: none;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
            box-shadow: 0 18px 30px rgba(37, 99, 235, 0.18);
        }

        .action-btn.primary {
            background: linear-gradient(90deg, #2EC4B6 0%, #0EA5E9 100%);
            color: #07101d;
        }

        .action-btn.secondary {
            background: rgba(255, 255, 255, 0.06);
            color: #e2e8f0;
            border: 1px solid rgba(255, 255, 255, 0.14);
        }

        .action-btn:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }

        .logout-note {
            margin-top: 1.8rem;
            color: #94a3b8;
            font-size: 0.95rem;
        }

        @media (max-width: 500px) {
            .actions {
                flex-direction: column;
            }

            .action-btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>

<div class="dashboard-card">
    <h1>Welcome to MovieMate 🎬</h1>
    <p class="subtitle">Your personal dashboard is ready. Browse movies, manage favorites, and stay logged in with one tap.</p>

    <div class="actions">
        <button class="action-btn primary" onclick="goMovies()">Browse Movies</button>
        <button class="action-btn secondary" onclick="logout()">Logout</button>
    </div>

    <p class="logout-note">Click logout when you're done. Your session will clear and return you to the login page.</p>
</div>

<script>
function goMovies() {
    window.location.href = "/movies-ssr";
}

function logout() {
    localStorage.removeItem("token");
    window.location.href = "/login";
}
</script>

</body>
</html>