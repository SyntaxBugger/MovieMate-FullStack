<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0, viewport-fit=cover">

    <title>MovieMate · Dashboard</title>

    <!-- Google Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet"
    >

    <!-- Font Awesome -->
    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    >

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            font-family: 'Inter', system-ui, 'Segoe UI', sans-serif;
            background: linear-gradient(
                135deg,
                #0B1F3A 0%,
                #0F2A44 100%
            );
            color: #edf2f8;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,...");
            pointer-events: none;
            z-index: 0;
        }

        .navbar {
            width: 100%;
            padding: 0.9rem 2rem;
            background: rgba(10, 20, 35, 0.75);
            backdrop-filter: blur(18px);
            border-bottom: 1px solid rgba(46, 196, 182, 0.25);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 0.85rem;
        }

        .video-logo {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            overflow: hidden;
            background: #0a1a2c;
        }

        .video-logo video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .logo-fallback {
            width: 100%;
            height: 100%;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            font-weight: bold;
            color: #07101d;
            background: linear-gradient(
                135deg,
                #2EC4B6,
                #0EA5E9
            );
        }

        .brand-text {
            font-size: 1.55rem;
            font-weight: 800;
            color: #ffffff;
        }

        .nav-links {
            display: flex;
            gap: 1.5rem;
        }

        .nav-link {
            color: #cbd5e6;
            cursor: pointer;
        }

        .dashboard-wrapper {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem 1.5rem;
        }

        .dashboard-card {
            width: min(580px, 100%);
            padding: 2.5rem 2rem;
            border-radius: 2rem;
            background: rgba(12, 22, 35, 0.72);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(46, 196, 182, 0.25);
            text-align: center;
            position: relative;
            z-index: 2;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0.3rem 1rem;
            border-radius: 40px;
            background: rgba(46, 196, 182, 0.12);
            color: #8ee4db;
            margin-bottom: 1.25rem;
        }

        h1 {
            font-size: clamp(2.2rem, 5vw, 3.2rem);
            margin-bottom: 0.75rem;
        }

        .subtitle {
            color: #cbd5e6;
            margin-bottom: 1.8rem;
            line-height: 1.6;
        }

        .stats-row {
            display: flex;
            gap: 1rem;
            margin: 1.5rem 0 1.8rem;
        }

        .stat-item {
            flex: 1;
            padding: 0.7rem;
            border-radius: 1.5rem;
            background: rgba(20, 30, 45, 0.65);
        }

        .stat-number {
            font-size: 1.6rem;
            font-weight: 800;
        }

        .stat-label {
            font-size: 0.7rem;
            color: #8eacc5;
        }

        .actions {
            display: flex;
            gap: 1.2rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .action-btn {
            padding: 0.85rem 2rem;
            border-radius: 999px;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }

        .primary {
            background: linear-gradient(
                105deg,
                #2EC4B6,
                #14b8db
            );
        }

        .secondary {
            background: rgba(20, 30, 45, 0.85);
            color: white;
        }

        .logout-note,
        .dashboard-footer {
            margin-top: 1.5rem;
        }

        @media (max-width: 650px) {
            .navbar {
                flex-direction: column;
            }

            .actions,
            .stats-row {
                flex-direction: column;
            }

            .action-btn {
                width: 100%;
            }
        }
    </style>
</head>

<body>

<nav class="navbar">
    <div class="logo-area">
        <div class="video-logo">
            <video
                id="logoVideo"
                autoplay
                loop
                muted
                playsinline
            >
                <source
                    src="/static/media_files/movielight.mp4"
                    type="video/mp4"
                >
            </video>

            <div
                class="logo-fallback"
                id="logoFallback"
            >
                ML
            </div>
        </div>

        <span class="brand-text">
            MovieMate
        </span>
    </div>

    <div class="nav-links">
        <span class="nav-link" id="navMovies">
            Browse Movies
        </span>
        <span class="nav-link" id="navLogin" style="display:none;">
            Login
        </span>
        <span class="nav-link" id="navLogout" style="display:none;">
            Logout
        </span>
    </div>
</nav>

<div class="dashboard-wrapper">
    <div class="dashboard-card">

        <div class="status-badge">

            <i class="fas fa-circle" style="font-size: 0.5rem; color: #2EC4B6;"></i> 
            <span><%= user ? 'verified session' : 'active session' %></span>
        </div>
        
        <h1><%= user && user.name ? 'Welcome back, ' + user.name : 'MovieMate' %></h1>
        <p class="subtitle">
            <%= user && user.name ? 'Your personal dashboard is ready. Browse movies, manage your watchlist, and enjoy your MovieMate experience.' : 'Your personal dashboard is ready. Browse movies, manage your watchlist, and experience seamless streaming — all in one refined space.' %>
        </p>

        <div class="stats-row">
            <div class="stat-item">
                <div class="stat-number">1.2k+</div>
                <div class="stat-label">Curated Films</div>
            </div>

            <div class="stat-item">
                <div class="stat-number">48</div>
                <div class="stat-label">Watchlist</div>
            </div>

            <div class="stat-item">
                <div class="stat-number">4.8</div>
                <div class="stat-label">Community</div>
            </div>
        </div>

        <div class="actions">
            <button
                class="action-btn primary"
                id="browseMoviesBtn"
            >
                <i class="fas fa-film"></i>
                Browse Movies
            </button>

            <button
                class="action-btn secondary"
                id="logoutBtn"
                style="display:none;"
            >
                <i class="fas fa-sign-out-alt"></i>
                Logout
            </button>

            <button
                class="action-btn secondary"
                id="loginActionBtn"
                style="display:none;"
                onclick="window.location.href = '/login'"
            >
                <i class="fas fa-sign-in-alt"></i>
                Login
            </button>
        </div>

        
    </div>
</div>

<script>
(function () {
    const token = localStorage.getItem("token");

    const browseBtn =
        document.getElementById("browseMoviesBtn");

    const logoutBtn =
        document.getElementById("logoutBtn");

    function goMovies() {
        window.location.href = "/movies-ssr";
    }

    function logout() {
        localStorage.removeItem("token");
        sessionStorage.removeItem("auth");
        window.location.href = "/login";
    }

    const navMovies = document.getElementById("navMovies");
    const navLogout = document.getElementById("navLogout");
    const navLogin = document.getElementById("navLogin");
    const loginActionBtn = document.getElementById("loginActionBtn");

    function updateAuthButtons() {
        const token = localStorage.getItem("token");
        const loggedIn = !!token;

        if (logoutBtn) {
            logoutBtn.style.display = loggedIn ? "inline-flex" : "none";
        }
        if (loginActionBtn) {
            loginActionBtn.style.display = loggedIn ? "none" : "inline-flex";
        }
        if (navLogout) {
            navLogout.style.display = loggedIn ? "inline-flex" : "none";
        }
        if (navLogin) {
            navLogin.style.display = loggedIn ? "none" : "inline-flex";
        }
    }

    if (browseBtn) {
        browseBtn.addEventListener(
            "click",
            goMovies
        );
    }

    if (navMovies) {
        navMovies.addEventListener("click", goMovies);
    }

    if (logoutBtn) {
        logoutBtn.addEventListener(
            "click",
            logout
        );
    }

    if (navLogout) {
        navLogout.addEventListener("click", logout);
    }

    if (navLogin) {
        navLogin.addEventListener("click", () => {
            window.location.href = "/login";
        });
    }

    updateAuthButtons();
})();
</script>

</body>
</html>